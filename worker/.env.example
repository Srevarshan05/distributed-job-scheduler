# Worker Server — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/job_scheduler

# ─── API server base URL (for internal calls if needed) ──────
API_BASE_URL=http://localhost:8000

# ─── Worker behaviour ────────────────────────────────────────
WORKER_ID=worker-1
POLL_INTERVAL_SECONDS=2
HEARTBEAT_INTERVAL_SECONDS=30
ORPHAN_TIMEOUT_SECONDS=90
MAX_RETRY_DELAY_SECONDS=3600

# ─── Server ──────────────────────────────────────────────────
WORKER_HOST=0.0.0.0
WORKER_PORT=8001
