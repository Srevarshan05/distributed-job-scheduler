# ─────────────────────────────────────────────────────────────────────────────
# JobRunR — Root Environment Variables
#
# Copy this to .env and fill in real values:
#   cp .env.example .env
#
# The actual .env is git-ignored. This file is committed as a template.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (used by the Docker db service) ────────────────────────────────
POSTGRES_USER=jobrunr
POSTGRES_PASSWORD=change-me-before-production
POSTGRES_DB=jobrunr

# ── Backend / Worker shared ───────────────────────────────────────────────────
# In Docker this is overridden per-service to use the db hostname.
# For local dev, set this to your local Postgres URL.
DATABASE_URL=postgresql+asyncpg://jobrunr:change-me-before-production@localhost:5432/jobrunr

JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Failure Summaries (optional) ──────────────────────────────────────────
# Leave blank to run without AI summaries. The app starts and runs normally
# without this key — the AI feature degrades gracefully to a plain summary.
GROQ_API_KEY=

# ── Frontend (used at build time by Vite) ────────────────────────────────────
# In Docker, the nginx proxy handles /api/* so this is only needed for local dev.
VITE_API_URL=http://localhost:8000
