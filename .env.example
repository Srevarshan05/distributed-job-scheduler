# ─────────────────────────────────────────────────────────────────────────────
# JobRunR — Root Environment Variables
#
# Copy this to .env and start the app — defaults work out of the box:
#   Windows PowerShell:   Copy-Item .env.example .env
#   Windows CMD:          copy .env.example .env
#   macOS / Linux:        cp .env.example .env
#
# Then run: docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=jobrunr
POSTGRES_PASSWORD=jobrunr_password
POSTGRES_DB=jobrunr

# ── Backend / Worker shared ───────────────────────────────────────────────────
# Inside Docker, this is auto-overridden by docker-compose.yml to use the db hostname.
# For local dev (no Docker), set this to your local Postgres connection string.
DATABASE_URL=postgresql+asyncpg://jobrunr:jobrunr_password@localhost:5432/jobrunr

JWT_SECRET=super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Failure Summaries (optional) ──────────────────────────────────────────
# Leave blank — app works perfectly without this. The AI summary feature simply
# shows a plain error message instead of an AI-generated one.
GROQ_API_KEY=

# ── Frontend (local dev only) ─────────────────────────────────────────────────
# In Docker, nginx proxies /api/* so this variable is NOT needed.
# Only set this when running the frontend locally with `npm run dev`.
VITE_API_URL=http://localhost:8000/api/v1
